// Get redemption statistics (for admin)
app.get('/api/loyalty/stats', async (req, res) => {
  try {
    const stats = await pool.query(`
      SELECT 
        COUNT(DISTINCT customer_id) as total_customers,
        COUNT(*) as total_redemptions,
        SUM(points_spent) as total_points_spent,
        AVG(points_spent) as avg_points_per_redemption
      FROM loyalty_redemptions
      WHERE redeemed_at >= NOW() - INTERVAL '30 days'
    `);

    const topProducts = await pool.query(`
      SELECT 
        p.name,
        p.category,
        COUNT(r.id) as redemption_count,
        SUM(r.quantity) as total_quantity,
        SUM(r.points_spent) as total_points
      FROM loyalty_redemptions r
      JOIN loyalty_products p ON r.product_id = p.id
      WHERE r.redeemed_at >= NOW() - INTERVAL '30 days'
      GROUP BY p.id, p.name, p.category
      ORDER BY redemption_count DESC
      LIMIT 10
    `);

    res.json({
      overview: stats.rows[0],
      topProducts: topProducts.rows
    });
  } catch (error) {
    console.error('Error fetching stats:', error);
    res.status(500).json({ error: 'Failed to fetch statistics' });
  }
});


