// Updated endpoint to use the recommended_orders table
app.get('/api/profile/recommended-order', authenticateUser, async (req, res) => {
  try {
    // Get customer ID
    const customerResult = await pool.query(
      'SELECT id FROM customers WHERE firebase_uid = $1',
      [req.user.firebaseUid]
    );
    if (customerResult.rows.length === 0) {
      return res.json({ items: [] });
    }
    const customerId = customerResult.rows[0].id;
    
    // Get recommended orders from the recommended_orders table
    const result = await pool.query(
      `SELECT 
        product_sku as id,
        product_name,
        product_sku,
        quantity,
        price,
        image_url,
        is_recommended,
        recommendation_reason
       FROM recommended_orders
       WHERE customer_id = $1
       ORDER BY is_recommended DESC, created_at DESC
       LIMIT 8`,
      [customerId]
    );
    
    // Transform data to ensure correct types
    const items = result.rows.map(item => ({
      id: item.id,
      product_name: item.product_name,
      product_sku: item.product_sku,
      quantity: parseInt(item.quantity) || 1,
      price: parseFloat(item.price),
      image_url: item.image_url,
      is_recommended: item.is_recommended,
      recommendation_reason: item.recommendation_reason
    }));
    
    res.json({ items });
    
  } catch (error) {
    console.error('Error fetching recommended order:', error);
    
    // Check if error is due to missing table
    if (error.code === '42P01') {
      // Table doesn't exist - return empty array instead of error
      console.log('recommended_orders table does not exist, returning empty recommendations');
      return res.json({ items: [] });
    }
    
    // For other errors, return 500
    res.status(500).json({ error: 'Failed to fetch recommended order' });
  }
});


