// Redeem product with points
app.post('/api/loyalty/redeem', async (req, res) => {
  const client = await pool.connect();
  
  try {
    const { customerId, productId, quantity = 1, redeemedBy } = req.body;

    if (!customerId || !productId) {
      return res.status(400).json({ error: 'customerId and productId are required' });
    }

    await client.query('BEGIN');

    // Get customer
    // Get customer
const isBarcode = customerId.toString().length === 13;

let customerResult = await client.query(
  `SELECT id, name, loyalty_points, ean13_barcode
   FROM customers
   WHERE ean13_barcode = $1`,
  [customerId]
);

// If not found by barcode, try by ID
if (customerResult.rows.length === 0 && !isNaN(parseInt(customerId))) {
  customerResult = await client.query(
    `SELECT id, name, loyalty_points, ean13_barcode
     FROM customers
     WHERE id = $1`,
    [parseInt(customerId)]
  );
}


    if (customerResult.rows.length === 0) {
      await client.query('ROLLBACK');
      return res.status(404).json({ error: 'Customer not found' });
    }

    const customer = customerResult.rows[0];
    const currentPoints = customer.loyalty_points || 0;

    // Get product
    const productResult = await client.query(
      `SELECT id, name, points_cost, stock_quantity, is_available
       FROM loyalty_products
       WHERE id = $1`,
      [productId]
    );

    if (productResult.rows.length === 0) {
      await client.query('ROLLBACK');
      return res.status(404).json({ error: 'Product not found' });
    }

    const product = productResult.rows[0];

    // Check if product is available
    if (!product.is_available) {
      await client.query('ROLLBACK');
      return res.status(400).json({ error: 'Product is not available' });
    }

    // Check stock
    if (product.stock_quantity < quantity) {
      await client.query('ROLLBACK');
      return res.status(400).json({ 
        error: 'Insufficient stock',
        available: product.stock_quantity
      });
    }

    // Calculate total cost
    const totalCost = product.points_cost * quantity;

    // Check if customer has enough points
    if (currentPoints < totalCost) {
      await client.query('ROLLBACK');
      return res.status(400).json({ 
        error: 'Insufficient points',
        required: totalCost,
        current: currentPoints,
        shortage: totalCost - currentPoints
      });
    }

    // Deduct points
    const newPoints = currentPoints - totalCost;
    await client.query(
      'UPDATE customers SET loyalty_points = $1 WHERE id = $2',
      [newPoints, customer.id]
    );

    // Update stock
    await client.query(
      'UPDATE loyalty_products SET stock_quantity = stock_quantity - $1 WHERE id = $2',
      [quantity, productId]
    );

    // Record redemption
    const redemptionResult = await client.query(
      `INSERT INTO loyalty_redemptions 
       (customer_id, product_id, points_spent, quantity, redeemed_by)
       VALUES ($1, $2, $3, $4, $5)
       RETURNING id, redeemed_at`,
      [customer.id, productId, totalCost, quantity, redeemedBy || 'Scanner']
    );

    await client.query('COMMIT');

    res.json({
      success: true,
      redemptionId: redemptionResult.rows[0].id,
      customerId: customer.id,
      customerName: customer.name,
      productName: product.name,
      quantity: quantity,
      pointsSpent: totalCost,
      previousPoints: currentPoints,
      newPoints: newPoints,
      redeemedAt: redemptionResult.rows[0].redeemed_at
    });

  } catch (error) {
    await client.query('ROLLBACK');
    console.error('Error redeeming product:', error);
    res.status(500).json({ error: 'Failed to redeem product' });
  } finally {
    client.release();
  }
});

