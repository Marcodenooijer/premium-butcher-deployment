        r.id,
        r.points_spent,
        r.quantity,
        r.redeemed_at,
        r.redeemed_by,
        p.name as product_name,
        p.category
       FROM loyalty_redemptions r
       JOIN loyalty_products p ON r.product_id = p.id
       WHERE r.customer_id = $1
       ORDER BY r.redeemed_at DESC
       LIMIT $2`,
      [customerId, limit]
    );

    res.json(result.rows);
