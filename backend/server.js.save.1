// ============================================

/**
 * Generate Google Wallet pass for current user
 * Returns a "Add to Google Wallet" URL
 */
app.get('/api/google-wallet/pass', authenticateUser, async (req, res) => {
  try {
    // Get customer data
    const customerResult = await pool.query(
      `SELECT id, name, email, ean13_barcode, loyalty_points, member_since 
       FROM customers 
       WHERE firebase_uid = $1`,
      [req.user.firebaseUid]
    );

    if (customerResult.rows.length === 0) {
      return res.status(404).json({ error: 'Customer not found' });
    }

    const customer = customerResult.rows[0];

    // Ensure customer has an EAN-13 barcode
    if (!customer.ean13_barcode) {
      const ean13 = await getOrCreateEAN13(customer.id, req.user.firebaseUid);
      customer.ean13_barcode = ean13;
    }

    // Create/update Google Wallet pass
    const saveUrl = await googleWallet.createLoyaltyObject({
      id: customer.id,
      name: customer.name,
      email: customer.email,
      ean13: customer.ean13_barcode,
      loyaltyPoints: customer.loyalty_points || 0,
      memberSince: customer.member_since
    });

    res.json({
      success: true,
      saveUrl: saveUrl,
      message: 'Google Wallet pass generated successfully'
    });

  } catch (error) {
    console.error('Error generating Google Wallet pass:', error);
    res.status(500).json({ 
      error: 'Failed to generate Google Wallet pass',
      details: error.message 
    });
  }
});

/**
 * Update loyalty points in Google Wallet
 * Called automatically when points change
 */
app.post('/api/google-wallet/update-points', authenticateUser, async (req, res) => {
  try {
    const { points } = req.body;

    // Get customer ID
    const customerResult = await pool.query(
      'SELECT id FROM customers WHERE firebase_uid = $1',
      [req.user.firebaseUid]
    );

    if (customerResult.rows.length === 0) {
      return res.status(404).json({ error: 'Customer not found' });
    }

    const customerId = customerResult.rows[0].id;

    // Update points in Google Wallet
    await googleWallet.updateLoyaltyPoints(customerId, points);

    res.json({
      success: true,
      message: 'Google Wallet pass updated successfully'
    });

  } catch (error) {
    console.error('Error updating Google Wallet pass:', error);
    res.status(500).json({ 
      error: 'Failed to update Google Wallet pass',
      details: error.message 
    });
  }
});

