// ============================================
// GOOGLE WALLET SERVICE - PREMIUM DESIGN
// ============================================
// Handles Google Wallet API integration for loyalty cards
// Enhanced with premium visual design and brand identity

const { google } = require('googleapis');
const jwt = require('jsonwebtoken');
const fs = require('fs');
const path = require('path');

// Load service account credentials
const keyFilePath = path.join(__dirname, 'credentials', 'google-wallet-key.json');
const serviceAccount = JSON.parse(fs.readFileSync(keyFilePath, 'utf8'));

// Configuration
const ISSUER_ID = '3388000000023082364';
const CLASS_ID = `${ISSUER_ID}.biologischvleeschatelierloyalty`;

/**
 * Initialize Google Wallet API client
 */
function getWalletClient() {
  const auth = new google.auth.GoogleAuth({
    credentials: serviceAccount,
    scopes: ['https://www.googleapis.com/auth/wallet_object.issuer'],
  });

  return google.walletobjects({
    version: 'v1',
    auth: auth,
  });
}

/**
 * Create or update the loyalty class (card template)
 * This defines the appearance and structure of all loyalty cards
 * PREMIUM DESIGN with enhanced visual elements
 */
async function createOrUpdateLoyaltyClass() {
  const client = getWalletClient();

  const loyaltyClass = {
    id: CLASS_ID,
    issuerName: 'Biologisch Vleesch Atelier',
    programName: 'Greetings from Romano',
    
    // PREMIUM: Enhanced logo with hero image
    programLogo: {
      sourceUri: {
        uri: 'https://www.elysia.marketing/Romano-logo.png'
      },
      contentDescription: {
        defaultValue: {
          language: 'nl-NL',
          value: 'Biologisch Vleesch Atelier - Premium Biologisch Vlees'
        }
      }
    },
    
    // PREMIUM: Hero image for visual impact
    heroImage: {
      sourceUri: {
        uri: 'https://images.unsplash.com/photo-1607623814075-e51df1bdc82f?auto=format&fit=crop&q=80&w=1032&h=336'
      },
      contentDescription: {
        defaultValue: {
          language: 'nl-NL',
          value: 'Biologisch Vleesch Atelier'
        }
      }
    },
    
    // PREMIUM: Deep forest green background (more sophisticated than brown)
    hexBackgroundColor: '#121212',
    
    reviewStatus: 'UNDER_REVIEW',
    
    // PREMIUM: Localized names in Dutch
    localizedIssuerName: {
      defaultValue: {
        language: 'nl-NL',
        value: 'Biologisch Vleesch Atelier'
      }
    },
    localizedProgramName: {
      defaultValue: {
        language: 'nl-NL',
        value: 'Welkom bij Romano'
      }
    },
    
    // PREMIUM: Add rewards tier information
    rewardsTier: 'Premium Member',
    rewardsTierLabel: 'Status',
    
    // PREMIUM: Program details with benefits
    programDetails: {
      defaultValue: {
        language: 'nl-NL',
        value: '100% Biologisch vlees van Nederlandse bodem • Grasgevoerd • SKAL Gecertificeerd • Gratis bezorging vanaf €120'
      }
    },
    
    // PREMIUM: Add messages for engagement
    messages: [
      {
        header: 'Welkom bij Biologisch Vleesch Atelier',
        body: 'Geniet van premium biologisch vlees, ambachtelijk bereid door Romano',
        id: 'welcome_message'
      }
    ],
    
    // PREMIUM: Multiple locations/links
    locations: [
      {
        latitude: 52.0705,
        longitude: 4.3007,
        kind: 'walletobjects#latLongPoint'
      }
    ],
    
    // PREMIUM: Add homepage URI
    homepageUri: {
      uri: 'https://biologischvleeschatelier.nl',
      description: 'Bezoek onze webshop',
      id: 'homepage'
    },
    
    // PREMIUM: Review highlights
    review: {
      comments: '⭐⭐⭐⭐⭐ Excellent kwaliteit biologisch vlees'
    }
  };

  try {
    // Try to get existing class
    await client.loyaltyclass.get({ resourceId: CLASS_ID });

    // Update if exists
    await client.loyaltyclass.update({
      resourceId: CLASS_ID,
