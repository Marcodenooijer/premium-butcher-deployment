/**
 * Create a loyalty object (individual customer's card)
 * PREMIUM DESIGN with enhanced personalization and visual elements
 * @param {Object} customerData - Customer information
 * @param {number} customerData.id - Customer ID
 * @param {string} customerData.name - Customer name
 * @param {string} customerData.email - Customer email
 * @param {string} customerData.ean13 - EAN-13 barcode
 * @param {number} customerData.loyaltyPoints - Loyalty points balance
 * @returns {string} - Save URL for "Add to Google Wallet" button
 */
async function createLoyaltyObject(customerData) {
  const client = getWalletClient();

  const objectId = `${ISSUER_ID}.${customerData.id}`;
  
  // Format member since date in Dutch
  const memberSinceDate = new Date(customerData.memberSince || Date.now());
  const dutchMonths = ['januari', 'februari', 'maart', 'april', 'mei', 'juni', 
                       'juli', 'augustus', 'september', 'oktober', 'november', 'december'];
  const formattedDate = `${dutchMonths[memberSinceDate.getMonth()]} ${memberSinceDate.getFullYear()}`;

  const loyaltyObject = {
    id: objectId,
    classId: CLASS_ID,
    state: 'ACTIVE',
    
    // PREMIUM: Enhanced account display
    accountName: customerData.name,
    accountId: `#${customerData.id.toString().padStart(6, '0')}`,
    
    // PREMIUM: Barcode with enhanced styling
    barcode: {
      type: 'QR_CODE',
      value: customerData.ean13,
      alternateText: customerData.ean13,
      kind: 'walletobjects#barcode'
    },
    
    // PREMIUM: Points with custom label
    loyaltyPoints: {
      label: 'Loyalty Punten',
      balance: {
       int: customerData.loyaltyPoints || 0
      }
    },

    
    // PREMIUM: Enhanced text modules with icons and Dutch language
    textModulesData: [
      {
        header: '👤 Lid Sinds',
        body: formattedDate,
        id: 'member_since'
      },
      {
        header: '🆔 Klant Nummer',
        body: `#${customerData.id.toString().padStart(6, '0')}`,
        id: 'customer_id'
      },
      {
        header: '✓ Jouw Voordelen',
        body: '• SKAL Bio Gecertificeerd\n• Exclusieve Kortingen\n• Gratis Bezorging €120+\n• Persoonlijke Aanbevelingen van Romano',
        id: 'benefits'
      },
      {
        header: '🥩 Kwaliteitsbelofte',
        body: '100% Biologisch vlees van Nederlandse bodem, grasgevoerd en ambachtelijk bereid',
        id: 'quality_promise'
      }
    ],
    
    // PREMIUM: Enhanced links with Dutch descriptions
    linksModuleData: {
      uris: [
        {
          uri: 'https://biologischvleeschatelier.profile.elysia.marketing',
          description: '📱 Bekijk Mijn Profiel',
          id: 'profile_link'
        },
        {
          uri: 'https://biologischvleeschatelier.nl',
          description: '🛒 Bezoek Webshop',
          id: 'website_link'
        },
        {
          uri: 'https://biologischvleeschatelier.nl/pages/contact',
          description: '📞 Contact Romano',
          id: 'contact_link'
        }
      ]
    },
    
    // PREMIUM: Add info module data for additional details
    infoModuleData: {
      showLastUpdateTime: true,
      labelValueRows: [
        {
          columns: [
            {
              label: 'Status',
              value: 'Premium Lid'
            },
            {
              label: 'Punten',
              value: `${customerData.loyaltyPoints || 0}`
            }
          ]
        }
      ]
    },
    
    // PREMIUM: Add messages for personalization
    messages: [
      {
        header: `Welkom ${customerData.name.split(' ')[0]}! 👋`,
        body: 'Bedankt voor je loyaliteit. Ontdek je persoonlijke aanbevelingen in je profiel.',
        id: 'welcome_message',
        messageType: 'TEXT'
      }
    ],
    
    // PREMIUM: Add valid time info
    validTimeInterval: {
      start: {
        date: memberSinceDate.toISOString()
      }
    }
  };

  try {
    // Try to get existing object
    await client.loyaltyobject.get({ resourceId: objectId });

    // Update if exists
    await client.loyaltyobject.update({
      resourceId: objectId,
      requestBody: loyaltyObject
    });

    console.log('✅ Premium loyalty object updated:', objectId);
  } catch (error) {
    if (error.code === 404) {
      // Create if doesn't exist
      await client.loyaltyobject.insert({
        requestBody: loyaltyObject
      });

      console.log('✅ Premium loyalty object created:', objectId);
    } else {
      throw error;
    }
  }

  // Generate JWT for "Add to Google Wallet" button
  const saveUrl = generateSaveUrl(loyaltyObject);
  return saveUrl;
}

/**
 * Generate JWT and "Add to Google Wallet" URL
 * @param {Object} loyaltyObject - The loyalty object
 * @returns {string} - Save URL
 */
function generateSaveUrl(loyaltyObject) {
  const claims = {
    iss: serviceAccount.client_email,
    aud: 'google',
    origins: [
      'https://biologischvleeschatelier.profile.elysia.marketing',
      'https://biologischvleeschatelier.nl'
    ],
    typ: 'savetowallet',
    payload: {
      loyaltyObjects: [loyaltyObject]
    }
  };

  const token = jwt.sign(claims, serviceAccount.private_key, {
    algorithm: 'RS256'
  });

  return `https://pay.google.com/gp/v/save/${token}`;
}

/**
 * Update loyalty points for an existing pass
 * PREMIUM: Includes notification message
 * @param {number} customerId - Customer ID
 * @param {number} newPoints - New points balance
 */
async function updateLoyaltyPoints(customerId, newPoints) {
  const client = getWalletClient();
  const objectId = `${ISSUER_ID}.${customerId}`;

  try {
    const response = await client.loyaltyobject.get({ resourceId: objectId });
    const loyaltyObject = response.data;

    // Update points
    loyaltyObject.loyaltyPoints.balance.int = newPoints;
     
    // PREMIUM: Add update message
    const pointsDifference = newPoints - (loyaltyObject.loyaltyPoints.balance.int || 0);
    if (pointsDifference > 0) {
      loyaltyObject.messages = [
        {
          header: '🎉 Punten Toegevoegd!',
          body: `Je hebt ${pointsDifference} punten verdiend! Je totaal is nu ${newPoints} punten.`,
          id: 'points_update',
          messageType: 'TEXT'
        }
      ];
    }

    await client.loyaltyobject.update({
      resourceId: objectId,
      requestBody: loyaltyObject
    });

    console.log(`✅ Updated loyalty points for customer ${customerId}: ${newPoints} (${pointsDifference > 0 ? '+' : ''}${pointsDifference})`);
  } catch (error) {
    console.error(`Error updating loyalty points for customer ${customerId}:`, error.message);
    throw error;
  }
}

module.exports = {
  createOrUpdateLoyaltyClass,
  createLoyaltyObject,
  updateLoyaltyPoints,
  ISSUER_ID,
  CLASS_ID
};

