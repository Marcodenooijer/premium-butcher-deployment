// ============================================
// EAN-13 BARCODE HELPER FUNCTIONS
// ============================================

/**
 * Calculate EAN-13 check digit
 * @param {string} code12 - First 12 digits of EAN-13
 * @returns {string} - Check digit (0-9)
 */
function calculateEAN13CheckDigit(code12) {
  // Ensure code12 is exactly 12 characters
  if (code12.length !== 12) {
    console.error('Invalid code12 length:', code12.length, 'value:', code12);
    throw new Error('code12 must be exactly 12 digits');
  }

  let sum = 0;
  for (let i = 0; i < 12; i++) {
    const char = code12.charAt(i);
    const digit = parseInt(char, 10);

    // Check if digit is valid
    if (isNaN(digit)) {
      console.error('Invalid digit at position', i, ':', char);
      throw new Error(`Invalid digit at position ${i}: ${char}`);
    }

    sum += (i % 2 === 0) ? digit : digit * 3;
  }

  const checkDigit = (10 - (sum % 10)) % 10;
  return checkDigit.toString();
}

/**
 * Generate unique EAN-13 barcode for customer
 * Pattern: 1563 99 XXXXX C (where C is check digit)
 * @param {number} customerId - Customer database ID
 * @returns {string} - Complete 13-digit EAN-13 barcode
 */
function generateEAN13Barcode(customerId) {
  // Prefix: 1563 99
  const prefix = '156399';

  // Generate 6-digit unique number from customer ID
  // Pad with zeros if needed, take last 6 digits if too long
  const uniquePart = customerId.toString().padStart(6, '0').slice(-6);

  // Combine prefix + unique part (12 digits total)
  const code12 = prefix + uniquePart;

  // Calculate check digit
  const checkDigit = calculateEAN13CheckDigit(code12);

  // Return complete EAN-13
  return code12 + checkDigit;
}

/**
 * Get or create EAN-13 barcode for customer
 * @param {number} customerId - Customer database ID
 * @param {string} firebaseUid - Firebase UID
 * @returns {Promise<string>} - EAN-13 barcode
 */
async function getOrCreateEAN13(customerId, firebaseUid) {
  // Check if customer already has an EAN-13 barcode
  const result = await pool.query(
    'SELECT ean13_barcode FROM customers WHERE id = $1',
    [customerId]
  );

  if (result.rows[0].ean13_barcode) {
    return result.rows[0].ean13_barcode;
  }

  // Generate new EAN-13 barcode
  const ean13 = generateEAN13Barcode(customerId);

  // Save to database
  await pool.query(
    'UPDATE customers SET ean13_barcode = $1 WHERE id = $2',
    [ean13, customerId]
  );

  return ean13;
}

// ============================================
// AUTHENTICATION MIDDLEWARE
// ============================================

const authenticateUser = async (req, res, next) => {
  try {
    const authHeader = req.headers.authorization;

    if (!authHeader || !authHeader.startsWith('Bearer ')) {
      return res.status(401).json({ error: 'No authorization token provided' });
    }

    const idToken = authHeader.split('Bearer ')[1];

    // Verify the Firebase ID token
    const decodedToken = await admin.auth().verifyIdToken(idToken);

    // Attach user info to request
    req.user = {
      firebaseUid: decodedToken.uid,
      email: decodedToken.email,
      name: decodedToken.name,
      picture: decodedToken.picture,
    };

    next();
  } catch (error) {
    console.error('Authentication error:', error);
    return res.status(401).json({ error: 'Invalid or expired token' });
  }
};

