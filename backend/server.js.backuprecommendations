// Generate EAN-13 barcode for current user
app.get('/api/barcode', authenticateUser, async (req, res) => {
  try {
    // Get customer ID
    const customerResult = await pool.query(
      'SELECT id FROM customers WHERE firebase_uid = $1',
      [req.user.firebaseUid]
    );

    if (customerResult.rows.length === 0) {
      return res.status(404).json({ error: 'Customer not found' });
    }

    const customerId = customerResult.rows[0].id;

    // Get or create EAN-13 barcode
    const ean13 = await getOrCreateEAN13(customerId, req.user.firebaseUid);

    // Generate the barcode image
    const png = await bwipjs.toBuffer({
      bcid: 'ean13',         // EAN-13 barcode type
      text: ean13,           // 13-digit barcode
      scale: 3,              // 3x scaling factor
      height: 10,            // Bar height, in millimeters
      includetext: true,     // Show human-readable text
      textxalign: 'center',  // Center align text
    });

    res.writeHead(200, {
      'Content-Type': 'image/png',
      'Content-Length': png.length,
    });
    res.end(png);
  } catch (error) {
    console.error('Error generating barcode:', error);
    res.status(500).json({ error: 'Failed to generate barcode' });
  }
});

